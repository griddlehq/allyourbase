# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Optional: For testing token exchange (expires quickly, obtain manually)
# GOOGLE_TEST_AUTH_CODE=4/0Adeu5...

# Optional: For testing user info endpoint (obtain via OAuth flow or Google OAuth Playground)
# GOOGLE_TEST_ACCESS_TOKEN=ya29.a0...

# Optional: For testing token refresh
# GOOGLE_TEST_REFRESH_TOKEN=1//0geu5...

# GitHub OAuth Credentials
GITHUB_CLIENT_ID=Iv1.1234567890abcdef
GITHUB_CLIENT_SECRET=your_github_client_secret_40_chars

# Optional: For testing token exchange (expires quickly, obtain manually)
# GITHUB_TEST_AUTH_CODE=abc123...

# Optional: For testing user info endpoint (obtain via OAuth flow or GitHub Settings > Developer settings > Personal access tokens)
# GITHUB_TEST_ACCESS_TOKEN=ghp_...
