{
  "name": "instantsearch-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:local-sdk": "npm --prefix ../../sdk run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:browser-tests": "eslint browser-tests-unmocked/**/*.spec.ts --config browser-tests-unmocked/eslint.config.mjs",
    "test:node-probe": "npm run build:local-sdk && node node_probe.mjs",
    "test:browser-tests": "npm run build:local-sdk && playwright test --config=playwright.config.ts --reporter=line"
  },
  "dependencies": {
    "@allyourbase/js": "file:../../sdk",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-instantsearch": "^7.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.2",
    "eslint-plugin-playwright": "^2.7.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.5.0",
    "typescript-eslint": "^8.56.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
